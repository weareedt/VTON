# FASHN v1.6 — required for the "Accurate" engine. Without it, that path returns a graceful 503.
FASHN_API_KEY=

# Upstash Redis (successor to Vercel KV) — link an Upstash Redis store from the
# Vercel Marketplace and these are auto-injected. Used only to hold the result
# image briefly for the QR download (short TTL, auto-purged). Optional: without it
# the QR is skipped and client-side download still works.
# For local `vercel dev`, pull these with `vercel env pull`.
# Either naming scheme works (KV_* or UPSTASH_REDIS_REST_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Reserved for the later Nano Banana 2 (Gemini) integration. Not used while NB2 is a placeholder.
GEMINI_API_KEY=
